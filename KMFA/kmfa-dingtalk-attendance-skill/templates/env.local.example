# Copy to KMFA/metadata/dingtalk_attendance/private_runtime/.env.local on a local machine.
# Never commit the copied .env.local file.

# DingTalk group robot notification.
DINGTALK_ROBOT_URL=<DINGTALK_GROUP_ROBOT_WEBHOOK_URL>
DINGTALK_ROBOT_SIGNING_KEY=<DINGTALK_GROUP_ROBOT_SIGNING_KEY>

# DingTalk work notification, optional unless that channel is used.
DINGTALK_BOSS_USER_ID=<BOSS_DINGTALK_USER_ID>
DINGTALK_APP_KEY=<DINGTALK_APP_KEY>
DINGTALK_APP_CREDENTIAL=<DINGTALK_APP_CREDENTIAL>
DINGTALK_CORP_ID=<DINGTALK_CORP_ID>
DINGTALK_AGENT_ID=<DINGTALK_AGENT_ID>

# DWS local CLI.
DWS_BIN=dws
KMFA_S19_ALLOW_DWS_COMMANDS=0
KMFA_S19_DWS_BROWSER_POLICY_PATH=/Users/<LOCAL_USER>/.dws/pat_policy.json
