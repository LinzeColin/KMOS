# Local-only example. Copy to private_runtime/.env.local and fill locally.
KMFA_REPO_ROOT=/Users/linzezhang/CodexProject/KMFA
KMFA_ONEDRIVE_ROOT=/Users/linzezhang/OneDrive/dingtalk_attendance
KMFA_PRIVATE_RUNTIME=/Users/linzezhang/CodexProject/KMFA/metadata/dingtalk_attendance/private_runtime
KMFA_ATTENDANCE_TZ=Asia/Shanghai
KMFA_REQUIRED_BRANCH=main

# DingTalk group robot notification.
DINGTALK_ROBOT_URL=replace_me
DINGTALK_ROBOT_SIGNING_KEY=replace_me

# DingTalk work notification, optional unless that channel is used.
DINGTALK_BOSS_USER_ID=replace_me
DINGTALK_APP_KEY=replace_me
DINGTALK_APP_CREDENTIAL=replace_me
DINGTALK_CORP_ID=replace_me
DINGTALK_AGENT_ID=replace_me

# DWS local CLI. Keep live commands disabled until explicitly authorized.
DWS_BIN=dws
KMFA_S19_ALLOW_DWS_COMMANDS=0
KMFA_S19_DWS_BROWSER_POLICY_PATH=/Users/LOCAL_USER/.dws/pat_policy.json

# Database target.
KMFA_DATABASE_URL=postgresql://kmfa_attendance:replace_me@localhost:5432/kmfa_attendance

# Stage-2 controls.
KMFA_STAGE2_REQUIRED_RUNS=5
KMFA_STAGE2_WINDOW_DAYS=1,2,3,4,5
KMFA_STAGE2_REQUIRED_SLOT=evening
KMFA_STAGE2_MIN_QUALITY=Q4
KMFA_REQUIRE_LOCATION_EVIDENCE=true
KMFA_REQUIRE_TRAJECTORY_EVIDENCE=true
