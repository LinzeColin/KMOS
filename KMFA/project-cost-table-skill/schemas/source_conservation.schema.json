{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kmfa.project_cost.source_conservation.v1",
  "$defs": {
    "item": {
      "type": "object",
      "required": ["item_ref", "relation_event_ref", "amount_minor", "absolute_amount_minor", "disposition", "reason_code"],
      "properties": {
        "item_ref": {"type": "string", "minLength": 1},
        "relation_event_ref": {"type": ["string", "null"]},
        "amount_minor": {"type": "integer"},
        "absolute_amount_minor": {"type": "integer", "minimum": 0},
        "disposition": {"enum": ["INCLUDED", "EXCLUDED", "PENDING", "PARSE_ERROR"]},
        "reason_code": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": [
    "schema_version", "reconciliation_id", "items", "source_control_count", "included_count", "excluded_count", "pending_count", "parse_error_count",
    "source_control_amount_minor", "included_amount_minor", "excluded_amount_minor", "pending_amount_minor", "parse_error_amount_minor",
    "source_control_absolute_minor", "included_absolute_minor", "excluded_absolute_minor", "pending_absolute_minor", "parse_error_absolute_minor",
    "source_conservation_delta_minor", "source_conservation_absolute_delta_minor", "channel_a_included_amount_minor", "channel_b_included_amount_minor",
    "dual_channel_delta_minor", "channel_a_included_absolute_minor", "channel_b_included_absolute_minor", "dual_channel_absolute_delta_minor",
    "conservation_status", "execution_status", "metric_inclusion_status", "company_approval_state_managed"
  ],
  "properties": {
    "schema_version": {"const": "kmfa.project_cost.source_conservation.v1"},
    "reconciliation_id": {"type": "string", "pattern": "^reconciliation_[0-9a-f]{32}$"},
    "items": {"type": "array", "items": {"$ref": "#/$defs/item"}},
    "source_control_count": {"type": "integer", "minimum": 0},
    "included_count": {"type": "integer", "minimum": 0},
    "excluded_count": {"type": "integer", "minimum": 0},
    "pending_count": {"type": "integer", "minimum": 0},
    "parse_error_count": {"type": "integer", "minimum": 0},
    "source_control_amount_minor": {"type": "integer"},
    "included_amount_minor": {"type": "integer"},
    "excluded_amount_minor": {"type": "integer"},
    "pending_amount_minor": {"type": "integer"},
    "parse_error_amount_minor": {"type": "integer"},
    "source_control_absolute_minor": {"type": "integer", "minimum": 0},
    "included_absolute_minor": {"type": "integer", "minimum": 0},
    "excluded_absolute_minor": {"type": "integer", "minimum": 0},
    "pending_absolute_minor": {"type": "integer", "minimum": 0},
    "parse_error_absolute_minor": {"type": "integer", "minimum": 0},
    "source_conservation_delta_minor": {"const": 0},
    "source_conservation_absolute_delta_minor": {"const": 0},
    "channel_a_included_amount_minor": {"type": "integer"},
    "channel_b_included_amount_minor": {"type": "integer"},
    "dual_channel_delta_minor": {"const": 0},
    "channel_a_included_absolute_minor": {"type": "integer", "minimum": 0},
    "channel_b_included_absolute_minor": {"type": "integer", "minimum": 0},
    "dual_channel_absolute_delta_minor": {"const": 0},
    "conservation_status": {"enum": ["PASS", "ERROR"]},
    "execution_status": {"enum": ["PASS", "BLOCKED", "ERROR"]},
    "metric_inclusion_status": {"const": "NOT_EVALUATED_R7"},
    "company_approval_state_managed": {"const": false}
  },
  "additionalProperties": false
}
