{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kmfa.project_cost.payroll_allocation.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "requested_metric_id", "formula_profile_id", "component_registry_id", "allocation_policy_id", "allocations", "reconciliations", "calculation_hash", "metric_inclusion_status"],
  "properties": {
    "schema_version": {"const": "kmfa.project_cost.payroll_allocation.v1"},
    "status": {"enum": ["PASS_R8_PAYROLL_CONTROLS_NOT_METRIC", "BLOCKED_R8_PAYROLL_CONTROLS"]},
    "requested_metric_id": {"type": "string", "minLength": 1},
    "formula_profile_id": {"type": "string", "pattern": "^formula_profile_[0-9a-f]{32}$"},
    "component_registry_id": {"type": "string", "pattern": "^pay_component_registry_[0-9a-f]{32}$"},
    "allocation_policy_id": {"type": "string", "pattern": "^payroll_policy_[0-9a-f]{32}$"},
    "allocations": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["legal_entity_id", "employee_id", "payroll_period", "requested_metric_id", "canonical_project_id", "wbs_or_cost_code", "approved_time_units", "allocated_amount_minor", "allocation_status", "metric_inclusion_status"],
        "properties": {
          "legal_entity_id": {"type": "string", "minLength": 1},
          "employee_id": {"type": "string", "pattern": "^employee_[0-9a-f]{32}$"},
          "payroll_period": {"type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"},
          "requested_metric_id": {"type": "string", "minLength": 1},
          "canonical_project_id": {"type": ["string", "null"]},
          "wbs_or_cost_code": {"type": ["string", "null"]},
          "approved_time_units": {"type": "integer", "minimum": 0},
          "allocated_amount_minor": {"type": "integer"},
          "allocation_status": {"enum": ["PROJECT_ALLOCATED", "UNALLOCATED_PAYROLL_POOL"]},
          "metric_inclusion_status": {"const": "NOT_EVALUATED_R8"}
        }
      }
    },
    "reconciliations": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["legal_entity_id", "employee_id", "payroll_period", "payroll_control_total_minor", "payroll_source_total_minor", "payroll_control_delta_minor", "allocable_employer_cost_minor", "excluded_component_amount_minor", "approved_time_control_units", "approved_time_source_units", "approved_time_delta_units", "project_allocated_amount_minor", "unallocated_payroll_amount_minor", "allocation_delta_minor", "status", "reason_codes"],
        "properties": {
          "legal_entity_id": {"type": "string", "minLength": 1},
          "employee_id": {"type": "string", "pattern": "^employee_[0-9a-f]{32}$"},
          "payroll_period": {"type": "string"},
          "payroll_control_total_minor": {"type": "integer"},
          "payroll_source_total_minor": {"type": "integer"},
          "payroll_control_delta_minor": {"type": "integer"},
          "allocable_employer_cost_minor": {"type": "integer"},
          "excluded_component_amount_minor": {"type": "integer"},
          "approved_time_control_units": {"type": "integer"},
          "approved_time_source_units": {"type": "integer"},
          "approved_time_delta_units": {"type": "integer"},
          "project_allocated_amount_minor": {"type": "integer"},
          "unallocated_payroll_amount_minor": {"type": "integer"},
          "allocation_delta_minor": {"const": 0},
          "status": {"enum": ["PASS_R8_PAYROLL_CONTROL", "BLOCKED_R8_PAYROLL_CONTROL"]},
          "reason_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    },
    "calculation_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "metric_inclusion_status": {"const": "NOT_EVALUATED_R8"}
  }
}
