{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kmfa.project_cost.expected_block_validation.private.v1",
  "type": "object",
  "required": [
    "schema_version",
    "validation_status",
    "execution_status",
    "input_readiness_status",
    "calculation_status",
    "generation_status",
    "production_exit_code_observed",
    "production_exit_code_expected",
    "exact_blocker_set_match",
    "expected_blocker_codes",
    "observed_blocker_codes",
    "project_count",
    "current_source_contract_sha256",
    "expected_block_contract_sha256",
    "production_request_hash_recomputed",
    "calculate_reference_data_flow_detected",
    "final_financial_workbook_generated",
    "internal_process_handoff_generated",
    "production_output_dir",
    "production_output_index",
    "validation_errors",
    "elapsed_ms",
    "production_stdout_sha256",
    "production_stderr_sha256",
    "production_command_argument_count"
  ],
  "properties": {
    "schema_version": {"const": "kmfa.project_cost.expected_block_validation.private.v1"},
    "validation_status": {"const": "PASS"},
    "execution_status": {"const": "EXPECTED_BLOCKED"},
    "input_readiness_status": {"const": "BLOCKED_NON_WAIVABLE"},
    "calculation_status": {"const": "BLOCKED_SOURCE"},
    "generation_status": {"const": "BLOCKED_DIAGNOSTICS_GENERATED"},
    "production_exit_code_observed": {"const": 3},
    "production_exit_code_expected": {"const": 3},
    "exact_blocker_set_match": {"const": true},
    "expected_blocker_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "observed_blocker_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "project_count": {"type": "integer", "minimum": 1},
    "current_source_contract_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "expected_block_contract_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "production_request_hash_recomputed": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "calculate_reference_data_flow_detected": {"const": false},
    "final_financial_workbook_generated": {"const": false},
    "internal_process_handoff_generated": {"const": false},
    "production_output_dir": {"type": "string", "pattern": "^/"},
    "production_output_index": {"type": "string", "pattern": "^/"},
    "validation_errors": {"const": []},
    "elapsed_ms": {"type": "integer", "minimum": 0},
    "production_stdout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "production_stderr_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "production_command_argument_count": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": false
}
