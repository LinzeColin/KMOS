{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/kmfa/economic_event_candidate.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "economic_event_id", "export_business_fingerprint", "source_business_key_hash",
    "source_business_digest", "mapping_rule_ref", "profile_sha256", "event_type", "direction", "lifecycle_stage",
    "event_status", "legal_entity_source_key", "project_source_key", "wbs_source_key", "contract_source_key",
    "counterparty_source_key", "document_id", "document_line_id", "document_date", "approval_date", "invoice_date",
    "payment_date", "collection_date", "effective_date", "reversal_date", "transaction_amount_minor",
    "gross_amount_minor", "net_amount_minor", "tax_amount_minor", "transaction_currency", "tax_recoverability",
    "source_arithmetic_status", "source_arithmetic_delta_minor", "reversal_of_source_key",
    "free_text_candidate_present", "identity_status", "metric_inclusion_status", "source_record_refs"
  ],
  "$defs": {
    "nullable_text": {"type": ["string", "null"]},
    "nullable_date": {"type": ["string", "null"], "format": "date"},
    "nullable_minor": {"type": ["integer", "null"], "minimum": -9223372036854775807, "maximum": 9223372036854775807}
  },
  "properties": {
    "schema_version": {"const": "kmfa.project_cost.economic_event_candidate.v1"},
    "economic_event_id": {"type": "string", "pattern": "^evt_[0-9a-f]{32}$"},
    "export_business_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_business_key_hash": {"type": "string", "pattern": "^lifecycle_line_[0-9a-f]{32}$"},
    "source_business_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "mapping_rule_ref": {"type": "string", "pattern": "^rule_[0-9a-f]{32}$"},
    "profile_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "event_type": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,63}$"},
    "direction": {"enum": ["COST", "REVENUE", "CASH_OUT", "CASH_IN"]},
    "lifecycle_stage": {"enum": ["BUDGET", "COMMITMENT", "ACCRUAL", "POSTED_ACTUAL", "PAID", "FORECAST", "CONTRACT_VALUE", "BILLED", "RECOGNIZED_REVENUE", "COLLECTED"]},
    "event_status": {"enum": ["SOURCE_ACTIVE", "SOURCE_PENDING", "SOURCE_CANCELLED", "SOURCE_REVERSED"]},
    "legal_entity_source_key": {"$ref": "#/$defs/nullable_text"},
    "project_source_key": {"$ref": "#/$defs/nullable_text"},
    "wbs_source_key": {"$ref": "#/$defs/nullable_text"},
    "contract_source_key": {"$ref": "#/$defs/nullable_text"},
    "counterparty_source_key": {"$ref": "#/$defs/nullable_text"},
    "document_id": {"$ref": "#/$defs/nullable_text"},
    "document_line_id": {"$ref": "#/$defs/nullable_text"},
    "document_date": {"$ref": "#/$defs/nullable_date"},
    "approval_date": {"$ref": "#/$defs/nullable_date"},
    "invoice_date": {"$ref": "#/$defs/nullable_date"},
    "payment_date": {"$ref": "#/$defs/nullable_date"},
    "collection_date": {"$ref": "#/$defs/nullable_date"},
    "effective_date": {"$ref": "#/$defs/nullable_date"},
    "reversal_date": {"$ref": "#/$defs/nullable_date"},
    "transaction_amount_minor": {"type": "integer", "minimum": -9223372036854775807, "maximum": 9223372036854775807},
    "gross_amount_minor": {"$ref": "#/$defs/nullable_minor"},
    "net_amount_minor": {"$ref": "#/$defs/nullable_minor"},
    "tax_amount_minor": {"$ref": "#/$defs/nullable_minor"},
    "transaction_currency": {"const": "CNY"},
    "tax_recoverability": {"const": "UNKNOWN"},
    "source_arithmetic_status": {"enum": ["BALANCED", "SOURCE_ARITHMETIC_DELTA", "INCOMPLETE", "NOT_APPLICABLE"]},
    "source_arithmetic_delta_minor": {"$ref": "#/$defs/nullable_minor"},
    "reversal_of_source_key": {"$ref": "#/$defs/nullable_text"},
    "free_text_candidate_present": {"type": "boolean"},
    "identity_status": {"const": "PENDING_IDENTITY"},
    "metric_inclusion_status": {"const": "NOT_EVALUATED_R6"},
    "source_record_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^rec_lifecycle_[0-9a-f]{32}$"}}
  }
}
