{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kmfa.project_cost.project_tax.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["record_id", "scope", "business_date", "gross_amount_minor", "tax_base_minor", "source_tax_amount_minor", "rate_numerator", "rate_denominator", "invoice_type", "recoverability", "recoverable_tax_minor", "source_tier", "evidence_refs", "company_policy_refs", "input_resolution_refs", "bound_input_hash"],
  "properties": {
    "record_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}_[0-9a-f]{32}$"},
    "scope": {"$ref": "#/$defs/scope"},
    "business_date": {"type": "string", "format": "date"},
    "gross_amount_minor": {"type": "integer", "minimum": 0},
    "tax_base_minor": {"type": "integer", "minimum": 0},
    "source_tax_amount_minor": {"type": "integer", "minimum": 0},
    "rate_numerator": {"type": "integer", "minimum": 0},
    "rate_denominator": {"type": "integer", "minimum": 1},
    "invoice_type": {"type": "string", "minLength": 1},
    "recoverability": {"enum": ["RECOVERABLE", "NON_RECOVERABLE", "PARTIALLY_RECOVERABLE"]},
    "recoverable_tax_minor": {"type": "integer", "minimum": 0},
    "source_tier": {"enum": ["DIRECT_PROJECT_EVIDENCE", "GOVERNED_PROJECT_LEDGER", "EVIDENCE_BACKED_ALLOCATION_POLICY"]},
    "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^evidence://sha256/[0-9a-f]{64}$"}},
    "company_policy_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^policy://sha256/[0-9a-f]{64}$"}},
    "input_resolution_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^resolution_[0-9a-f]{32}$"}},
    "bound_input_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "scope": {
      "type": "object", "additionalProperties": false,
      "required": ["metric_id", "legal_entity_id", "canonical_project_id", "wbs_or_cost_code"],
      "properties": {
        "metric_id": {"type": "string", "minLength": 1},
        "legal_entity_id": {"type": "string", "minLength": 1},
        "canonical_project_id": {"type": "string", "minLength": 1},
        "wbs_or_cost_code": {"type": "string", "minLength": 1}
      }
    }
  }
}
