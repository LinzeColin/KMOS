{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kmfa.project_cost.manual_adjustment.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["adjustment_id", "metric_id", "lifecycle_stage", "legal_entity_id", "canonical_project_id", "wbs_or_cost_code", "cost_category", "amount_minor", "amount_sign", "business_date", "posting_period", "reason", "evidence_refs", "formula_profile_id", "company_policy_refs", "input_resolution_refs", "valid_from", "valid_to", "expires_on", "reversal_policy", "supersedes", "reverses", "bound_request_hash", "bound_input_hash", "bound_config_hash", "status", "metric_inclusion_status"],
  "properties": {
    "adjustment_id": {"type": "string", "pattern": "^adjustment_[0-9a-f]{32}$"},
    "metric_id": {"type": "string", "minLength": 1},
    "lifecycle_stage": {"enum": ["ACCRUAL", "POSTED_ACTUAL", "PAID", "FORECAST"]},
    "legal_entity_id": {"type": "string", "minLength": 1},
    "canonical_project_id": {"type": "string", "minLength": 1},
    "wbs_or_cost_code": {"type": "string", "minLength": 1},
    "cost_category": {"type": "string", "minLength": 1},
    "amount_minor": {"type": "integer"},
    "amount_sign": {"enum": ["POSITIVE", "NEGATIVE"]},
    "business_date": {"type": "string", "format": "date"},
    "posting_period": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1},
    "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^evidence://sha256/[0-9a-f]{64}$"}},
    "formula_profile_id": {"type": "string", "pattern": "^formula_profile_[0-9a-f]{32}$"},
    "company_policy_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^policy://sha256/[0-9a-f]{64}$"}},
    "input_resolution_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^resolution_[0-9a-f]{32}$"}},
    "valid_from": {"type": "string", "format": "date"},
    "valid_to": {"type": ["string", "null"], "format": "date"},
    "expires_on": {"type": ["string", "null"], "format": "date"},
    "reversal_policy": {"enum": ["EXPLICIT_REVERSAL_RECORD_REQUIRED", "NO_AUTOMATIC_REVERSAL"]},
    "supersedes": {"type": ["string", "null"], "pattern": "^adjustment_[0-9a-f]{32}$"},
    "reverses": {"type": ["string", "null"], "pattern": "^adjustment_[0-9a-f]{32}$"},
    "bound_request_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "bound_input_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "bound_config_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "status": {"enum": ["ACTIVE", "TEMPLATE_NOT_ACTIVE", "SUPERSEDED", "REVERSED", "EXPIRED"]},
    "metric_inclusion_status": {"const": "NOT_EVALUATED_R8"}
  },
  "allOf": [{"anyOf": [{"properties": {"company_policy_refs": {"minItems": 1}}}, {"properties": {"input_resolution_refs": {"minItems": 1}}}]}]
}
