{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/kmfa/kingdee_bundle_profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_id", "status", "schema_id", "bundle_source_sha256", "evidence_refs", "members"],
  "properties": {
    "schema_version": {"const": "kmfa.project_cost.kingdee_bundle_profile.v1"},
    "profile_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["ACTIVE", "TEMPLATE_NOT_ACTIVE"]},
    "schema_id": {"type": "string", "minLength": 1},
    "bundle_source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^evidence://sha256/[0-9a-f]{64}$"}
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["member_path", "member_sha256", "disposition", "exclusion_reason_code", "reader_profile_id", "evidence_ref"],
        "properties": {
          "member_path": {"type": "string", "minLength": 5, "pattern": "\\.[xX][lL][sS]([xX])?$"},
          "member_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "disposition": {"enum": ["INCLUDE", "EXCLUDE_QUALIFIED_SCOPE"]},
          "exclusion_reason_code": {"type": ["string", "null"], "minLength": 1},
          "reader_profile_id": {"type": ["string", "null"], "minLength": 1},
          "evidence_ref": {"type": ["string", "null"], "pattern": "^evidence://sha256/[0-9a-f]{64}$"}
        },
        "allOf": [
          {
            "if": {"properties": {"disposition": {"const": "INCLUDE"}}, "required": ["disposition"]},
            "then": {"properties": {"exclusion_reason_code": {"type": "null"}}},
            "else": {
              "properties": {
                "exclusion_reason_code": {"type": "string", "minLength": 1},
                "reader_profile_id": {"type": "null"}
              }
            }
          },
          {
            "if": {
              "properties": {
                "disposition": {"const": "INCLUDE"},
                "member_path": {"pattern": "\\.[xX][lL][sS][xX]$"}
              },
              "required": ["disposition", "member_path"]
            },
            "then": {"properties": {"reader_profile_id": {"type": "string", "minLength": 1}}}
          }
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "ACTIVE"}}, "required": ["status"]},
      "then": {
        "properties": {
          "evidence_refs": {"minItems": 1},
          "members": {
            "items": {"properties": {"evidence_ref": {"type": "string"}}}
          }
        }
      }
    }
  ]
}
