{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kmfa.project_cost.pay_component_registry.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_id", "registry_version", "status", "valid_from", "valid_to", "base_currency", "rules", "evidence_refs", "company_policy_refs", "bound_config_hash"],
  "properties": {
    "schema_version": {"const": "kmfa.project_cost.pay_component_registry.v1"},
    "registry_id": {"type": "string", "pattern": "^pay_component_registry_[0-9a-f]{32}$"},
    "registry_version": {"type": "string", "minLength": 1},
    "status": {"enum": ["ACTIVE", "TEMPLATE_NOT_ACTIVE"]},
    "valid_from": {"type": "string", "format": "date"},
    "valid_to": {"type": ["string", "null"], "format": "date"},
    "base_currency": {"const": "CNY"},
    "rules": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["component_id", "treatment", "legal_entity_id", "valid_from", "valid_to", "evidence_refs"],
        "properties": {
          "component_id": {"type": "string", "minLength": 1},
          "treatment": {"enum": ["INCLUDED_EMPLOYER_COST", "EXCLUDED_FROM_EMPLOYER_COST", "EXTERNAL_LABOR_NOT_PAYROLL"]},
          "legal_entity_id": {"type": "string", "minLength": 1},
          "valid_from": {"type": "string", "format": "date"},
          "valid_to": {"type": ["string", "null"], "format": "date"},
          "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^evidence://sha256/[0-9a-f]{64}$"}}
        }
      }
    },
    "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^evidence://sha256/[0-9a-f]{64}$"}},
    "company_policy_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^policy://sha256/[0-9a-f]{64}$"}},
    "bound_config_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
  }
}
