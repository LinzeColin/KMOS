{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/kmfa/kingdee_ledger_record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_record_ref", "source_business_key_hash", "normalized_business_digest", "source_id", "source_sha256", "slot_id", "reader_id", "reader_version", "schema_id", "schema_fingerprint", "sheet_name", "sheet_ref", "row_number", "legal_entity_source_key", "project_source_key", "wbs_source_key", "contract_source_key", "account_code", "voucher_id", "voucher_line_id", "document_date", "business_date", "posting_date", "debit_minor", "credit_minor", "balance_minor", "currency", "source_status", "source_row_kind", "container_source_id", "container_sha256", "archive_member_ref"],
  "properties": {
    "schema_version": {"const": "kmfa.project_cost.kingdee_ledger_record.v1"},
    "source_record_ref": {"type": "string", "pattern": "^rec_source_[0-9a-f]{32}$"},
    "source_business_key_hash": {"type": "string", "pattern": "^ledger_line_[0-9a-f]{32}$"},
    "normalized_business_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_id": {"type": "string", "minLength": 1},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "slot_id": {"const": "general_ledger"},
    "reader_id": {"const": "kingdee_ledger_v2"},
    "reader_version": {"const": "2.0.0"},
    "schema_id": {"type": "string", "minLength": 1},
    "schema_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "sheet_name": {"type": "string", "minLength": 1},
    "sheet_ref": {"type": "string", "pattern": "^sheet_[0-9a-f]{16}$"},
    "row_number": {"type": "integer", "minimum": 1},
    "legal_entity_source_key": {"type": ["string", "null"]},
    "project_source_key": {"type": ["string", "null"]},
    "wbs_source_key": {"type": ["string", "null"]},
    "contract_source_key": {"type": ["string", "null"]},
    "account_code": {"type": ["string", "null"]},
    "voucher_id": {"type": ["string", "null"]},
    "voucher_line_id": {"type": ["string", "null"]},
    "document_date": {"type": ["string", "null"], "format": "date"},
    "business_date": {"type": ["string", "null"], "format": "date"},
    "posting_date": {"type": ["string", "null"], "format": "date"},
    "debit_minor": {"type": ["integer", "null"]},
    "credit_minor": {"type": ["integer", "null"]},
    "balance_minor": {"type": ["integer", "null"]},
    "currency": {"type": ["string", "null"]},
    "source_status": {"type": ["string", "null"]},
    "source_row_kind": {"type": ["string", "null"]},
    "container_source_id": {"type": ["string", "null"], "pattern": "^src_[0-9a-f]{32}$"},
    "container_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "archive_member_ref": {"type": ["string", "null"], "pattern": "^member_[0-9a-f]{32}$"}
  }
}
