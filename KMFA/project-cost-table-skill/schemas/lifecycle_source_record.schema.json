{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/kmfa/lifecycle_source_record.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "source_record_ref", "source_business_key_hash", "normalized_business_digest", "unbound_content_digest",
    "source_id", "source_sha256", "slot_id", "reader_id", "reader_version", "schema_id", "schema_fingerprint",
    "profile_sha256", "sheet_name", "sheet_ref", "row_number", "row_action", "exclusion_reason_code",
    "legal_entity_source_key", "project_source_key", "wbs_source_key", "contract_source_key", "counterparty_source_key",
    "document_id", "document_line_id", "source_event_type", "source_status", "source_row_kind", "reversal_of_source_key",
    "free_text", "document_date", "approval_date", "invoice_date", "payment_date", "collection_date", "effective_date",
    "reversal_date", "transaction_amount_minor", "gross_amount_minor", "net_amount_minor", "tax_amount_minor", "currency",
    "source_arithmetic_status", "source_arithmetic_delta_minor"
  ],
  "$defs": {
    "nullable_text": {"type": ["string", "null"]},
    "nullable_date": {"type": ["string", "null"], "format": "date"},
    "nullable_minor": {"type": ["integer", "null"], "minimum": -9223372036854775807, "maximum": 9223372036854775807}
  },
  "properties": {
    "schema_version": {"const": "kmfa.project_cost.lifecycle_source_record.v1"},
    "source_record_ref": {"type": "string", "pattern": "^rec_lifecycle_[0-9a-f]{32}$"},
    "source_business_key_hash": {"type": "string", "pattern": "^lifecycle_line_[0-9a-f]{32}$"},
    "normalized_business_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "unbound_content_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_id": {"type": "string", "pattern": "^src_[0-9a-f]{32}$"},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "slot_id": {"enum": ["project_billing", "cash_out", "contract_and_changes", "cash_in"]},
    "reader_id": {"enum": ["project_invoice_v2", "payment_v2", "contract_change_v2", "collection_v2"]},
    "reader_version": {"const": "2.0.0"},
    "schema_id": {"type": "string", "minLength": 1},
    "schema_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "profile_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "sheet_name": {"type": "string", "minLength": 1},
    "sheet_ref": {"type": "string", "pattern": "^sheet_[0-9a-f]{16}$"},
    "row_number": {"type": "integer", "minimum": 1},
    "row_action": {"enum": ["EMIT_EVENT", "EXCLUDE_CONTROL"]},
    "exclusion_reason_code": {"type": ["string", "null"], "pattern": "^[A-Z][A-Z0-9_]{1,63}$"},
    "legal_entity_source_key": {"$ref": "#/$defs/nullable_text"},
    "project_source_key": {"$ref": "#/$defs/nullable_text"},
    "wbs_source_key": {"$ref": "#/$defs/nullable_text"},
    "contract_source_key": {"$ref": "#/$defs/nullable_text"},
    "counterparty_source_key": {"$ref": "#/$defs/nullable_text"},
    "document_id": {"$ref": "#/$defs/nullable_text"},
    "document_line_id": {"$ref": "#/$defs/nullable_text"},
    "source_event_type": {"$ref": "#/$defs/nullable_text"},
    "source_status": {"$ref": "#/$defs/nullable_text"},
    "source_row_kind": {"$ref": "#/$defs/nullable_text"},
    "reversal_of_source_key": {"$ref": "#/$defs/nullable_text"},
    "free_text": {"$ref": "#/$defs/nullable_text"},
    "document_date": {"$ref": "#/$defs/nullable_date"},
    "approval_date": {"$ref": "#/$defs/nullable_date"},
    "invoice_date": {"$ref": "#/$defs/nullable_date"},
    "payment_date": {"$ref": "#/$defs/nullable_date"},
    "collection_date": {"$ref": "#/$defs/nullable_date"},
    "effective_date": {"$ref": "#/$defs/nullable_date"},
    "reversal_date": {"$ref": "#/$defs/nullable_date"},
    "transaction_amount_minor": {"$ref": "#/$defs/nullable_minor"},
    "gross_amount_minor": {"$ref": "#/$defs/nullable_minor"},
    "net_amount_minor": {"$ref": "#/$defs/nullable_minor"},
    "tax_amount_minor": {"$ref": "#/$defs/nullable_minor"},
    "currency": {"type": ["string", "null"]},
    "source_arithmetic_status": {"enum": ["BALANCED", "SOURCE_ARITHMETIC_DELTA", "INCOMPLETE", "NOT_APPLICABLE"]},
    "source_arithmetic_delta_minor": {"$ref": "#/$defs/nullable_minor"}
  }
}
