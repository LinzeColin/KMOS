{
  "version": "0.1.0",
  "automation_id": "dingtalk-routine-check",
  "automation_name": "Dingtalk-routine-check / 钉钉工作检查",
  "status": "ACTIVE",
  "kind": "cron",
  "timezone": "Asia/Shanghai",
  "execution_environment": "local",
  "cwd": "/Users/linzezhang/CodexProject",
  "skill_path": "KMFA/daily_routine_check_skill/SKILL.md",
  "rrule": "DTSTART;TZID=Asia/Shanghai:20260708T113500\nRRULE:FREQ=DAILY\nDTSTART;TZID=Asia/Shanghai:20260708T170500\nRRULE:FREQ=DAILY",
  "trigger_windows": [
    {
      "trigger_window": "morning_1135",
      "run_time_beijing": "11:35",
      "command": "python3 -m KMFA.tools.daily_routine_check.main --date today --timezone Asia/Shanghai --trigger-window morning_1135 --send --cleanup --apply"
    },
    {
      "trigger_window": "evening_1705",
      "run_time_beijing": "17:05",
      "command": "python3 -m KMFA.tools.daily_routine_check.main --date today --timezone Asia/Shanghai --trigger-window evening_1705 --send --cleanup --apply"
    }
  ],
  "single_automation_only": true,
  "do_not_create_one_automation_per_rule": true,
  "required_run_log_fields": [
    "run_at_beijing",
    "check_date",
    "trigger_window",
    "rules_evaluated",
    "rules_blocked_by_source",
    "rules_skipped"
  ],
  "cash_monitor_fields": [
    "cash_risk_result",
    "risk_level",
    "total_available_cash"
  ],
  "source_quality_events": [
    "SOURCE_MISSING",
    "SOURCE_STALE",
    "ZIP_INPUT_UNREADABLE"
  ],
  "zip_input_primary": true,
  "zip_input_path": "DWS_Outputs.zip",
  "zip_required_members": [
    "DWS_Outputs/付款请示群/chat_records/chat_records.csv",
    "DWS_Outputs/付款请示群/_manifest/manifest.csv",
    "DWS_Outputs/生产管理群/chat_records/chat_records.csv",
    "DWS_Outputs/生产管理群/_manifest/manifest.csv"
  ],
  "direct_input_fallback": "DWS_Outputs/<群>/chat_records/chat_records.csv and DWS_Outputs/<群>/_manifest/manifest.csv",
  "private_runtime_policy": "Do not commit notification targets, SQLite, raw DWS output, OCR raw bodies, webhook URLs, tokens, resolved DingTalk IDs, screenshots, or notification receipts."
}
