{
  "schema_version": "kmfa.raw_manifest_schema.v1",
  "stage_phase": "S03-P1",
  "record_type": "raw_file_manifest",
  "required_fields": [
    "record_type",
    "import_run_id",
    "source_id",
    "file_hash",
    "file_size_bytes",
    "storage_ref",
    "original_filename_hash",
    "file_format",
    "container_type",
    "received_at",
    "manifest_status",
    "source_package_ref",
    "evidence_ref"
  ],
  "immutable_fields": [
    "import_run_id",
    "source_id",
    "file_hash",
    "storage_ref",
    "original_filename_hash"
  ],
  "allowed_manifest_statuses": [
    "registered",
    "superseded",
    "rejected",
    "quarantined"
  ],
  "supported_s03p1_file_formats": [
    "zip",
    "xlsx",
    "xls",
    "csv",
    "pdf",
    "wps"
  ],
  "forbidden_fields": [
    "raw_file_bytes",
    "raw_value",
    "original_value",
    "plaintext_content",
    "full_file_text",
    "bank_account_number",
    "identity_document_number",
    "password",
    "token",
    "api_key",
    "private_key"
  ],
  "raw_file_bytes_public_repo_allowed": false,
  "raw_extracted_values_public_repo_allowed": false
}
