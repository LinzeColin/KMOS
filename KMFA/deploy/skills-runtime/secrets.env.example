# KMFA skills 云端凭据键位清单（示例，无值）。
# 真实文件：云主机 /opt/kmfa/secrets/skills.env，权限 600，任何情况不入仓。

# —— 守卫开关（考勤 dws_auth_guard 的 READY 条件之一；dws 登录+browser-policy 完成后置 1）
KMFA_DINGTALK_ATTENDANCE_ALLOW_DWS_COMMANDS=

# —— 投递总开关（双跑纪律：比对通过并经 Owner 同意前保持 0）
KMFA_DELIVERY_ENABLED=

# —— 钉钉群机器人（群投递通道，按渠道解析文件的键位）
DINGTALK_ROBOT_URL=
DINGTALK_ROBOT_SIGNING_KEY=

# —— 钉钉个人 DING 通道（notifier_dws_personal_chat 的 dws_ding_personal 渠道）
DINGTALK_DING_ROBOT_CODE=

# —— 云端失败告警 webhook（run_skill.sh 使用；建议指向 Owner 个人/测试群）
KMFA_ALERT_WEBHOOK_TOKEN=

# —— 考勤根目录覆盖（容器内仓库路径固定时通常不需要）
# KMFA_ATTENDANCE_LOCAL_KMFA_ROOT=/opt/kmfa/KMOS/KMFA
