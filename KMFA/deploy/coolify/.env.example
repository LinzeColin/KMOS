# KMFA Coolify 环境变量键位清单（示例，无值）。
# 设置位置：Coolify → 该资源 → Environment Variables；敏感项勾 "Is Secret"
#   （Coolify 以其 APP_KEY 静态加密；compose 内只写 ${KEY} 占位，值绝不入仓 / 入日志）。
# 命名：UPPER_SNAKE。skills 读容器环境即可（缺值按既有设计告警 / 空跑，不阻塞起容器）。
# dws 登录态：**不是环境变量**——由 Coolify 托管的 named volume `kmfa-dws-auth` 持久；
#   Owner 首启做一次 `dws auth login --device`（手机点一次）即写入，之后无人值守（无 KMFA_DWS_TOKEN 这种键）。

# ==== 非敏感配置（普通 Env）====
# 投递总开关（双跑纪律：比对通过并经 Owner 同意前保持 0）
KMFA_DELIVERY_ENABLED=0
# 考勤 dws 双闸之一（dws 登录 + browser-policy 完成后置 1）
KMFA_DINGTALK_ATTENDANCE_ALLOW_DWS_COMMANDS=0
# 公共增强 App Shell；灰度异常时置 0 并重部署，仅回退到稳定静态壳，不动数据/私有面。
KMFA_PUBLIC_SHELL_ENABLED=1
# 搜索索引灰度；默认 0 会让根页保持人类可用，但 robots 全拒绝、sitemap 为空且根响应 noindex。
# 仅在根路径公开、私有路径与未发布 canary 负测全绿后置 1；回滚只需恢复 0 并重部署。
KMFA_PUBLIC_INDEXING_ENABLED=0
# S03/P3.4 早期匿名可恢复文件骨架；默认 0。仅在 app state named volume 已挂载、
# 重启/恢复/download-hash/Flag rollback Oracle 全绿后灰度置 1；回滚恢复 0，不删卷。
KMFA_WALKING_SKELETON_ENABLED=0
# 私有运维面源站守卫。生产必须为 1；缺少下列任一可信配置时 /api*、/ops* 会 fail-closed 503。
KMFA_PRIVATE_OPS_REQUIRE_ACCESS=1
# Cloudflare Zero Trust team domain，可填主机名或 https URL（非 token/凭据）。
KMFA_CLOUDFLARE_ACCESS_TEAM_DOMAIN=
# 覆盖 /api、/api/*、/ops、/ops/* 的 Access Application Audience tags，逗号分隔。
KMFA_CLOUDFLARE_ACCESS_AUD=

# ==== 敏感（Coolify 勾 "Is Secret"）====
# 钉钉群机器人（群投递通道）
DINGTALK_ROBOT_URL=
DINGTALK_ROBOT_SIGNING_KEY=
# 钉钉个人 DING 通道
DINGTALK_DING_ROBOT_CODE=
# 云端失败告警 webhook token（run_skill.sh 实读此名——勿简写为 KMFA_ALERT_WEBHOOK）
KMFA_ALERT_WEBHOOK_TOKEN=
