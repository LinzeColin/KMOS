    "execute_cleanup": false,
    "execute_vacuum": false,
    "execute_reindex": false,
    "execute_backup": false,
    "execute_restore": false,
    "write_runtime_outputs": false,
    "read_raw_metadata": false,
    "write_raw_metadata": false,
    "install_dependencies": false,
    "start_services": false,
    "github_upload": false,
    "app_reinstall": false
  }
