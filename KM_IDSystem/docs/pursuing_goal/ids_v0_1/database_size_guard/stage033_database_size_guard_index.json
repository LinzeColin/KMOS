    "sql_file_created": false,
    "migration_executed": false,
    "connection_config_created": false,
    "recovery_smoke_executed": false,
    "live_schema_diff_executed": false,
    "tracked_constraints": [
      "postgres_control_plane_scope_only",
      "no_raw_content_storage",
      "no_ocr_full_text_storage",
      "no_large_file_or_report_binary_storage",
      "bounded_derived_artifacts_only",
      "bounded_row_payload_policy",
