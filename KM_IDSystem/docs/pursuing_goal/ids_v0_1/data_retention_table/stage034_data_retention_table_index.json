      "unknown_subject_allowed": false,
      "raw_payload_subject_allowed": false,
      "owner_summary": "数据保留表只覆盖临时文件、缓存、旧索引、日志和报告快照"
    },
    "ttl_policy_guard": {
      "ttl_required": true,
      "keep_until_required": true,
      "expiration_reason_required": true,
      "warning_window_required": true,
      "runtime_expiry_scan_allowed": false,
      "owner_summary": "每一类保留对象都必须有 TTL、keep-until 和中文到期原因"
    },
    "owner_hold_guard": {
      "manual_hold_allowed": true,
      "compliance_hold_allowed": true,
      "owner_hold_blocks_cleanup": true,
      "owner_reason_required": true,
      "runtime_hold_update_allowed": false,
      "owner_summary": "人工 hold 或合规 hold 必须阻断清理、删除、压缩、驱逐或裁剪"
    },
    "cleanup_dry_run_guard": {
      "cleanup_default_mode": "dry_run_only",
      "owner_impact_report_required": true,
      "no_delete_proof_required": true,
      "auto_delete_allowed": false,
      "runtime_cleanup_allowed": false,
      "owner_summary": "清理默认只能 dry-run，必须先给出影响说明和不删除证明"
    },
    "deletion_stop_gate_guard": {
      "owner_stop_gate_required": true,
      "destructive_action_allowed_by_default": false,
      "retention_deletion_allowed": false,
      "log_compaction_allowed": false,
      "cache_eviction_allowed": false,
      "old_index_rebuild_allowed": false,
      "report_snapshot_pruning_allowed": false,
      "owner_summary": "删除、压缩、驱逐、重建或报告快照裁剪都必须由后续 owner stop gate 单独授权"
    },
    "audit_evidence_guard": {
      "audit_evidence_ref_required": true,
      "event_ref_required": true,
      "fact_level_required": true,
      "chinese_owner_reason_required": true,
      "runtime_audit_write_allowed": false,
      "owner_summary": "每个保留状态变化必须能追溯到 event、evidence、fact level 和中文原因"
    },
    "rollback_restore_guard": {
      "rollback_restore_ref_required": true,
      "requires_stage031_migration_safety_ref": true,
