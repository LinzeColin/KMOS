{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence_bundle.schema.json",
  "title": "EvidenceBundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "bundle_id", "lot_id", "official_url", "artifacts", "evidence_quality", "missing"],
  "properties": {
    "contract_version": {"const": "0.4.1"},
    "bundle_id": {"type": "string", "minLength": 1},
    "lot_id": {"type": "string", "minLength": 1},
    "official_url": {"type": "string", "format": "uri"},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "source_url", "sha256", "media_type", "parser", "parser_version", "parse_status", "spans"],
        "properties": {
          "artifact_id": {"type": "string", "minLength": 1},
          "source_url": {"type": "string", "format": "uri"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "media_type": {"type": "string", "minLength": 1},
          "parser": {"type": ["string", "null"]},
          "parser_version": {"type": ["string", "null"]},
          "parse_status": {"enum": ["ok", "partial", "failed", "blocked"]},
          "spans": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["span_id", "locator", "text_hash", "ocr"],
              "properties": {
                "span_id": {"type": "string"},
                "locator": {"type": "string", "description": "page, paragraph, table/cell or bounding-box locator"},
                "text_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                "ocr": {
                  "type": ["object", "null"],
                  "additionalProperties": false,
                  "required": ["engine", "version", "language", "confidence"],
                  "properties": {
                    "engine": {"type": "string"},
                    "version": {"type": "string"},
                    "language": {"type": "string"},
                    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
                  }
                }
              }
            }
          }
        }
      }
    },
    "evidence_quality": {"enum": ["complete", "partial", "insufficient"]},
    "missing": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "reason_code", "next_action"],
        "properties": {
          "field": {"type": "string"},
          "reason_code": {"type": "string"},
          "next_action": {"type": "string"}
        }
      }
    }
  }
}
