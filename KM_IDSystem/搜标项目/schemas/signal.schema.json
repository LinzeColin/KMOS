{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "signal.schema.json",
  "title": "ProcurementSignal",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "signal_id", "signal_type", "source_id", "source_url", "observed_at_raw", "horizon", "confidence", "evidence_refs", "current_notice_status"],
  "properties": {
    "contract_version": {"const": "0.4.1"},
    "signal_id": {"type": "string", "minLength": 1},
    "signal_type": {"enum": ["procurement_intent", "annual_plan", "maintenance_plan", "contract_expiry", "historical_recurrence", "winner_subcontract", "supplier_onboarding"]},
    "source_id": {"type": "string"},
    "source_url": {"type": "string", "format": "uri"},
    "observed_at_raw": {"type": "string"},
    "horizon": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "current_notice_status": {"const": "NOT_A_CURRENT_NOTICE"}
  }
}
