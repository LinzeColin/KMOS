{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LifecycleResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "dws_contract_hash", "ledger_versions", "outcomes", "competitors", "recurrence"],
  "properties": {
    "contract_version": {"const": "0.4.1"},
    "dws_contract_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "ledger_versions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["row_version_id", "message_id", "file_sha256", "sheet", "row_locator", "formula", "displayed_value", "observed_at_raw"],
        "properties": {
          "row_version_id": {"type": "string"},
          "message_id": {"type": "string"},
          "file_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "sheet": {"type": "string"},
          "row_locator": {"type": "string"},
          "formula": {"type": ["string", "null"]},
          "displayed_value": {"type": ["string", "number", "boolean", "null"]},
          "observed_at_raw": {"type": "string"}
        }
      }
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lot_id", "outcome_status", "official_evidence_refs"],
        "properties": {
          "lot_id": {"type": "string"},
          "outcome_status": {"enum": ["OUTCOME_PENDING", "QUALIFICATION_PASSED", "QUALIFICATION_REJECTED", "CANDIDATE_WINNER", "FINAL_WIN", "FINAL_LOSS", "CANCELLED", "FAILED", "REOPENED"]},
          "official_evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "competitors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lot_id", "entity_name", "result_state", "evidence_refs"],
        "properties": {
          "lot_id": {"type": "string"},
          "entity_name": {"type": "string"},
          "result_state": {"type": "string"},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "recurrence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signal_id", "basis", "horizon", "confidence"],
        "properties": {
          "signal_id": {"type": "string"},
          "basis": {"type": "string"},
          "horizon": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    }
  }
}
